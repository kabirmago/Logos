# Copy this file to .env.local locally, and add these as Railway env vars in production.

# Gemini API key — get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key-here"

# Session secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="replace-with-a-long-random-string"

# Admin seed password — sets the KabirMago admin password on first run
ADMIN_SEED_PASSWORD="choose-a-strong-password"

# PostHog analytics (VITE_ prefix exposes frontend vars to the browser bundle)
VITE_PUBLIC_POSTHOG_TOKEN="phc_..."
VITE_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
POSTHOG_TOKEN="phc_..."
POSTHOG_HOST="https://us.i.posthog.com"

# Firebase (prefix VITE_ so Vite exposes them to the browser bundle)
VITE_FIREBASE_API_KEY="your-firebase-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
VITE_FIREBASE_APP_ID="your-app-id"
VITE_FIREBASE_FIRESTORE_DB_ID="your-firestore-database-id"
